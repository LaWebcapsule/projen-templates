{
  "name": "test2",
  "scripts": {
    "build": "npx projen build",
    "compile": "npx projen compile",
    "default": "npx projen default",
    "eslint": "npx projen eslint",
    "install:local": "npx projen install:local",
    "package": "npx projen package",
    "post-compile": "npx projen post-compile",
    "pre-compile": "npx projen pre-compile",
    "test": "npx projen test",
    "test:watch": "npx projen test:watch",
    "watch": "npx projen watch",
    "projen": "npx projen"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "@wbce-d9/extensions-sdk": "^10.0.2",
    "@wbce-d9/types": "^10.1.0",
    "@wbce/projen-directus-extension": "^0.0.0",
    "eslint": "^9",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "jest": "^30.3.0",
    "jest-junit": "^16",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "main": "lib/index.js",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.0.0",
  "jest": {
    "coverageProvider": "v8",
    "testMatch": [
      "<rootDir>/@(src|test)/**/*(*.)@(spec|test).ts?(x)",
      "<rootDir>/@(src|test)/**/__tests__/**/*.ts?(x)"
    ],
    "clearMocks": true,
    "collectCoverage": true,
    "coverageReporters": [
      "json",
      "lcov",
      "clover",
      "cobertura",
      "text"
    ],
    "coverageDirectory": "coverage",
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/"
    ],
    "watchPathIgnorePatterns": [
      "/node_modules/"
    ],
    "reporters": [
      "default",
      [
        "jest-junit",
        {
          "outputDirectory": "test-reports"
        }
      ]
    ],
    "transform": {
      "^.+\\.[t]sx?$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.dev.json"
        }
      ]
    }
  },
  "types": "lib/index.d.ts",
  "directus:extension": {
    "host": "^9.27.2",
    "type": "bundle",
    "path": {
      "api": "dist/api.js"
    },
    "entries": [
      {
        "type": "hook",
        "name": "sensitive-fields-hook",
        "source": "src/sensitive-fields-hook/index.ts"
      },
      {
        "type": "endpoint",
        "name": "sensitive-fields-decrypt",
        "source": "src/sensitive-fields-decrypt/index.ts"
      },
      {
        "type": "interface",
        "name": "sensitive-fields-interface",
        "source": "src/sensitive-fields-interface/index.ts"
      },
      {
        "type": "hook",
        "name": "test2-hook",
        "source": "src/test2-hook/index.ts"
      },
      {
        "type": "endpoint",
        "name": "test2-endpoint",
        "source": "src/test2-endpoint/index.ts"
      }
    ]
  },
  "//": "~~ Generated by projen. To modify, edit .projenrc.js and run \"npx projen\"."
}
