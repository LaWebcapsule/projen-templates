FROM node:22-bookworm-slim

# Update npm to fix dependencies (step-id: update-npm)
RUN npm install -g npm@11.8.0

# install pnpm (step-id: install-pnpm)
RUN wget -qO- https://get.pnpm.io/install.sh | ENV="$HOME/.bashrc" SHELL="$(which bash)" PNPM_VERSION="10.33.0" bash -

# Copy package.json first to leverage Docker layer caching (step-id: copy-package)
COPY package.json /app/

# Set working directory (step-id: workdir)
WORKDIR /app

# Install dependencies - without dev dependencies (step-id: install-deps)
RUN NODE_ENV=production npm install

# Cleaning benchmarks folder in tedious module for security (step-id: cleanup)
RUN rm -rf node_modules/tedious/benchmarks

# Copy the rest of the application code (step-id: copy-source)
COPY . .

# build extensions (step-id: build-extension)
RUN npx projen build-extensions

# Start Directus server (step-id: start)
CMD ["npx","directus","start"]